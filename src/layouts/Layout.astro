---
import { Image } from 'astro:assets';
import hart_rond from '../assets/rondevormen/hart_rond.png'
import "../styles/global.css"
import Nav from '../components/Nav.astro';
import LanguagePicker from '../components/LanguagePicker.astro';
import { getLangFromUrl, useTranslatedPath, useTranslations } from '../i18n/utils';

interface Props {
	title: string;
	description?: string; 
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const pathname = new URL(Astro.url).pathname;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const { title, description = "Standaard omschrijving voor Mooyo" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description}>
		<meta name="keywords" content="Astro, coaching">
		<title>{title} | Mooyo</title>
		<link rel="icon" type="image/png" href={`${baseUrl}/favicon.png`} />
		<link rel="canonical" href={canonicalURL} />
	</head>
	<body>
		<header>
			<LanguagePicker place='header'/>
			<div>
				<Image src={hart_rond} alt="Mooyo logo" height={100} width={100} loading="eager"/>
				<h1><span class="big-text">Mooyo -</span> {t('layout.header.subtitle')}</h1>
			</div>
			<Nav pathname={pathname}/>
		</header>
		<main>
			<slot />
		</main>
		<footer class="back-black text-gray">
			<p>© 2026 Mooyo</p>
			<div class="flex">
				<div>
					<p>Mooyo</p>
					<ul class="none-list">
    					<li><a href={translatePath('/')}>{t('footer.home')}</a></li>
    					<li><a href={translatePath('/filosofie')}>{t('footer.filosofie')}</a></li>
    					<li><a href={translatePath('/aanbod')}>{t('footer.aanbod')}</a></li>
    					<li><a href={translatePath('/about')}>{t('footer.about')}</a></li>
    					<li><a href="https://www.hartcirkels.be">www.hartcirkels.be</a></li>
    					<li><a href="https://www.reconstructive.be">www.reconstructive.be</a></li>
					</ul>
				</div>
				<div>
					<p>Bram Geysen</p>
					<p>+32 473 52 30 94</p>
					<p><a href="mailto:bramgeysen@gmail.com">bramgeysen@gmail.com</a></p>
				</div>
				<div>
					<p>{t('footer.artwork')}</p>
					<p>{t('footer.zon')}</p>
					<p>{t('footer.website')}</p>
					<p><a href="mailto:nielgeysen@gmail.com">nielgeysen@gmail.com</a></p>
				</div>
				<div>
					<LanguagePicker place='footer'/>
				</div>
			</div>
		</footer>
	</body>
</html>

<style>
	header {
		display: flex;
		align-items: center;
		flex-direction: column;
		gap: 4rem;
		color: var(--mooyo-text-red);
		background-color: var(--mooyo-white);
		padding: 3rem ;
	}

	header div {
		display: flex;
		align-items: center;
		gap: 5rem;
	}
	header .big-text{
    	font-size: 48px;
	}

	section {
		padding: 2rem;
	}

	footer {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		margin: auto;
	}

	footer p {
		color: var(--text-gray);
		font-size: 1.1rem;
	}

	footer .flex {
		display: flex;
		justify-content: space-around;
		width: 100%;
	}

	footer .ul {
		list-style-type: none;
	}


	/* Responsive */

	@media (max-width: 800px){
		footer .flex{
			flex-direction: column;
			width: 50%;
			margin: auto;
		}
	}

    @media (max-width: 700px ){
        header {
            gap: 3rem;
        }
    }

	@media (max-width: 500px){
		header div {
			flex-direction: column;
			gap: 1rem;
			justify-content: center;
		}

		header {
			padding-top: 7rem;
			text-align: center;
		}
	}
</style>
