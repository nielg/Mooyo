---
import { Image } from 'astro:assets';
import hart_rond from '../assets/rondevormen/hart_rond.png'
import "../styles/global.css"
import Nav from '../components/Nav.astro';
import LanguagePicker from '../components/LanguagePicker.astro';
import { getLangFromUrl, useTranslatedPath, useTranslations } from '../i18n/utils';

interface Props {
	title: string;
	description?: string; 
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const pathname = new URL(Astro.url).pathname;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const { title, description = "Standaard omschrijving voor Mooyo" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={`${baseUrl}/favicon.png`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Mooyo</title>
		<meta name="description" content={description}>
		<link rel="canonical" href={canonicalURL} />
	</head>
	<body>
		<header>
			<LanguagePicker/>
			<div>
				<Image src={hart_rond} alt="Mooyo logo" height={100} width={100} loading="eager"/>
				<h1><span class="big-text">Mooyo -</span> {t('layout.header.subtitle')}</h1>
			</div>
			<Nav pathname={pathname}/>
		</header>
		<main>
			<slot />
			{pathname != "/" && (
				<section class="back-gray text-align-center text-gray">
					<p>{t('layout.contact')}</p>
					<p>+32 473 52 30 94</p>
					<p>
  						<a href="mailto:bramgeysen@gmail.com" class="border-bottom">bramgeysen@gmail.com</a>
					</p>
				</section>
			)}
		</main>
		<footer class="back-black text-gray">
			<p>© 2026 Mooyo</p>
			<div class="flex">
				<div>
					<p>Links</p>
					<ul>
						<li><a href={translatePath('/')}></a>{t('footer.home')}</li>
						<li><a href={translatePath('/filosofie')}></a>{t('footer.filosofie')}</li>
						<li><a href={translatePath('/aanbod')}></a>{t('footer.aanbod')}</li>
						<li><a href={translatePath('/hartcirkels')}></a>{t('footer.hartcirkels')}</li>
						<li><a href={translatePath('/about')}></a>{t('footer.about')}</li>
						<li><a href="">www.hartcirkels.be</a></li>
						<li><a href="">www.reconstructive.be</a></li>
					</ul>
				</div>
				<div class="text-align-center">
					<p>{t('footer.madeBy')}</p>
					<p><a href="mailto:nielgeysen@gmail.com">nielgeysen@gmail.com</a></p>
				</div>
			</div>
		</footer>
	</body>
</html>

<style>
	header {
		display: flex;
		align-items: center;
		flex-direction: column;
		gap: 4rem;
		color: var(--mooyo-text-red);
		background-color: var(--mooyo-white);
		padding: 3rem ;
	}

	header div {
		display: flex;
		align-items: center;
		gap: 5rem;
	}
	header .big-text{
    	font-size: 48px;
	}

	section {
		padding: 2rem;
	}

	footer {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		margin: auto;
	}

	footer p {
		color: var(--text-gray);
		font-size: 1.1rem;
	}

	footer .flex {
		display: flex;
		justify-content: space-between;
		width: 80%;
	}

	.border-bottom{
		border-bottom: 1px solid var(--mooyo-text-gray);
	}

	/* Responsive */

    @media (max-width: 700px ){
        header {
            gap: 3rem;
        }
    }

	@media (max-width: 500px){
		header div {
			flex-direction: column;
			gap: 1rem;
			justify-content: center;
		}

		header {
			padding-top: 7rem;
			text-align: center;
		}
	}
</style>
