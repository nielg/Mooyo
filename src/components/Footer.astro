---
import '../styles/global.css'
import { getLangFromUrl, useTranslatedPath, useTranslations } from '../i18n/utils';
import LanguagePicker from '../components/LanguagePicker.astro';
const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
const t = useTranslations(lang);


---

<footer class="back-black text-white">
    <div class="row">
        <h3>Mooyo</h3>
        <LanguagePicker place='footer'/>
    </div>
    <div class="col3">
	    <div>
		    <h4>Navigation</h4>
			<ul class="none-list">
			    <li><a href={translatePath('/')}>{t('footer.home')}</a></li>
    			<li><a href={translatePath('/filosofie')}>{t('footer.filosofie')}</a></li>
    			<li><a href={translatePath('/aanbod')}>{t('footer.aanbod')}</a></li>
    			<li><a href={translatePath('/about')}>{t('footer.about')}</a></li>
    			<li><a href="https://www.hartcirkels.be">www.hartcirkels.be</a></li>
    			<li><a href="https://www.reconstructive.be">www.reconstructive.be</a></li>
			</ul>
		</div>
		<div>
		    <h4>Bram Geysen</h4>
			<p>+32 473 52 30 94</p>
			<a href="mailto:bramgeysen@gmail.com">bramgeysen@gmail.com</a>
        </div>
		<div class="credits">
            <h4>Credits</h4>
			<p>{t('footer.artwork')}</p>
			<p>{t('footer.zon')}</p>
			<p>{t('footer.website')} <a href="mailto:nielgeysen@gmail.com">nielgeysen@gmail.com</a></p>
        </div>
	</div>
	<p class="text-align-center">© 2026 Mooyo</p>
</footer>


<style>
    footer {
        color: #b7aaaa;
    }
    

    .row {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        padding: 0 2rem;
    }

    .col3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        column-gap: 1rem;
        margin: 1rem 2rem;
    }
    .ul {
		list-style-type: none;
	}

    p{
        margin: 0.5rem;
    }

    @media (max-width: 750px ) {
        .col3 {
            grid-template-columns: 1fr;
        }
    }
</style>