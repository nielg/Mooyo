---
import { record } from 'astro:schema';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
    color: "white" | "red"
	reconstructive?: boolean 
}

const {color, reconstructive = true} = Astro.props

const sectionClasses = color === "red"
    ? "back-red text-white"
    : "back-white";
---

<section class=`center ${sectionClasses}`>
    <h2>{t('Prices.title')}</h2>
	<p class="online-p text-align-center">{t('Prices.text')}</p>
	<div class="col3">
		<div class="card">
			<h4 class="bold text-red">{t('Prices.e1.title1')}</h4>
			<ul class="infinity-list text-black">
				<li>{t('Prices.e1.li1')}</li>
				<li>{t('Prices.e1.li2')}</li>
			</ul>
			<p class="seeMore">Zie meer...</p>
			<div class="details">
				<p>{t('Prices.e1.details.text1')}</p>
				<div>
					<h4>{t('Prices.e1.details.title')}</h4>
					<p>{t('Prices.e1.details.text2')}</p>
				</div>
			</div>
		</div>
		<div class="card">
			<h4 class="bold text-red">{t('Prices.e2.title1')}</h4>
			<ul class="infinity-list text-black">
				<li>{t('Prices.e2.li1')}</li>
				<li>{t('Prices.e2.li2')}</li>
			</ul>
			<p class="seeMore">Zie meer...</p>
			<div class="details">
				<p>{t('Prices.e2.details')}</p>
			</div>
		</div>
		<div class="card">
			<h4 class="bold text-red">{t('Prices.e3.title')}</h4>
			<ul class="infinity-list text-black">
				<li>{t('Prices.e3.li1')}</li>
				<li>{t('Prices.e3.li2')}</li>
			</ul>
			<p class="seeMore">Zie meer...</p>
			<div class="details">
				<p>{t('Prices.e3.details')}</p>
			</div>
		</div>
	</div>
	{reconstructive && 
		<div class="text-align-center card">
	    	<h4 class="bold text-red">{t('Prices.e4.title')}</h4>
			<p class="text-black">{t('Prices.e4.text1')}</p>
			<p class="text-black">{t('Prices.e4.text2')}</p>
		</div>
	}
</section>

<style>
    section {
		padding: 2rem;
	}

    .online-p {
        width: 75%;
    }

    .col3{
		grid-template-columns: 1fr 1fr 1fr;
	}

	.card {
		background-color: var(--mooyo-gray);
		padding: 2rem;
		border-radius: 0.5rem;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
		margin: 1rem;
		color: black;
	}
	
	.card .details {
		transition: all 0.4s ease-in-out; 
		transition-delay: 0.4s;
    	opacity: 0;
    	visibility: hidden;
    	max-height: 0;
    	overflow: hidden;
    	transform: translateY(10px);
	}
	
	.card:hover .details {
		opacity: 1;
    	visibility: visible;
	    max-height: 1000px; 
    	transform: translateY(0);
	}
	
	.seeMore {
		margin-bottom: 0;
		transition: all 0.4s ease-in-out; 
	}
	.card:hover .seeMore {
		opacity: 0;
	}



    @media (max-width: 1200px){
		.col2 {
			display: flex;
			flex-direction: column;
			width: 70vw;
			max-width: 500px;
		}

		section {
			display: flex;
			align-items: center;
			justify-content: center;
		}
	}
</style>