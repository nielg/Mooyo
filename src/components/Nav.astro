---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
const t = useTranslations(lang);

interface Props {
    pathname: string
}
const {pathname} = Astro.props;

---

<nav>
    <a href={translatePath('/')} class={pathname.endsWith('/') ? "text-red" : ""}>HOME</a>
    <a href={translatePath('/filosofie')} class={pathname.endsWith('/filosofie/') ? "text-red" : ""}>{t('nav.filosofie')}</a>
    <a href={translatePath('/aanbod')} class={pathname.endsWith('/aanbod/') ? "text-red" : ""}>{t('nav.aanbod')}</a>
    <a href={translatePath('/hartcirkels')} class={pathname.endsWith('/hartcirkels/') ? "text-red" : ""}>{t('nav.hartcirkels')}</a>
    <a href={translatePath('/about')} class={pathname.endsWith('/about/') ? "text-red" : ""}>{t('nav.about')}</a>
</nav>

<style>
    nav {
        display: flex;
        align-items: center;
        gap: 3rem;
    }
    a {
        padding: 0 0.7rem 0.5rem 0.7rem;
        display: inline-block;
        border-bottom: 1px solid white;
    }
    a:hover{
        transform: scale(1.2);
        border-color: var(--mooyo-red);
        transition: all 0.2s ease;
    }

    /* Responsive */

    @media (max-width: 800px ){
        nav {
            flex-direction: column;
            gap: 2rem;
        }
    }
</style>