---
import { Image } from 'astro:assets';
import Layout from "../../../layouts/Layout.astro"
import adem_rond from '../../../assets/rondevormen/adem_rond.png'
import bewustzijn_rond from '../../../assets/rondevormen/bewustzijn_rond.png'
import hart_rond from '../../../assets/rondevormen/hart_rond.png'
import lichaam_rond from '../../../assets/rondevormen/lichaam_rond.png'

import { getLangFromUrl, useTranslations, getStaticPaths } from '../../../i18n/utils';
import ContactSection from '@components/Contact-section.astro';
export { getStaticPaths };
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t("filosofie.title")}>
    <section class="intro-pillars back-red text-align-center text-white">
        <p class="p2" set:html={t("intro-pillars.text1")}/>
        <p class="bold" set:html={t("intro-pillars.text2")}/>
    </section>
    <section class="pillars back-gray text-align-center center text-gray">
        <div class="col2">
            <div>
                <h3 class="text-red">{t('pillars.bewustzijn.title1')}</h3>
                <div class="img-container bold">
                    <Image src={bewustzijn_rond} alt="Tekening van bewustzijn" height={400} width={400}/>
                    <div class="img-text">
                        <p>{t('pillars.bewustzijn.img.text1')}</p>
                        <p>{t('pillars.bewustzijn.img.text2')}</p>
                    </div>
                </div>
                <h4 class="text-red">{t('pillars.bewustzijn.title2')}</h4>
                <ul class="text-align-justify infinity-list">
                    <li>{t('pillars.bewustzijn.list1')}</li>
                    <li>{t('pillars.bewustzijn.list2')}</li>
                    <li>{t('pillars.bewustzijn.list3')}</li>
                    <li>{t('pillars.bewustzijn.list4')}</li>
                </ul>
            </div>
    
            <div>
                <h3 class="text-red">{t('pillars.adem.title1')}</h3>
                <div class="img-container bold">
                    <Image src={adem_rond} alt="Tekening van adem" height={400} width={400}/>
                    <div class="img-text">
                        <p>{t('pillars.adem.img.text1')}</p>
                        <p>{t('pillars.adem.img.text2')}</p>
                    </div>
                </div>
                <h4 class="text-red">{t('pillars.adem.title2')}</h4>
                <ul class="text-align-justify infinity-list">
                    <li>{t('pillars.adem.list1')}</li>
                    <li>{t('pillars.adem.list2')}</li>
                    <li>{t('pillars.adem.list3')}</li>
                    <li>{t('pillars.adem.list4')}</li>
                </ul>
            </div>
    
            <div>
                <h3 class="text-red">{t('pillars.hart.title1')}</h3>
                <div class="img-container bold">
                    <Image src={hart_rond} alt="Tekening van hart" height={400} width={400}/>
                    <div class="img-text">
                        <p>{t('pillars.hart.img.text1')}</p>
                        <p>{t('pillars.hart.img.text2')}</p>
                    </div>
                </div>
                <h4 class="text-red">{t('pillars.hart.title2')}</h4>
                <ul class="text-align-justify infinity-list">
                    <li>{t('pillars.hart.list1')}</li>
                    <li>{t('pillars.hart.list2')}</li>
                    <li>{t('pillars.hart.list3')}</li>
                </ul>
            </div>
    
            <div>
                <h3 class="text-red">{t('pillars.e4.title1')}</h3>
                <div class="img-container bold">
                    <Image src={lichaam_rond} alt="Tekening van lichaam" height={400} width={400}/>
                    <div class="img-text">
                        <p>{t('pillars.e4.img.text1')}</p>
                        <p>{t('pillars.e4.img.text2')}</p>
                    </div>
                </div>
                <h4 class="text-red">{t('pillars.e4.title2')}</h4>
                <ul class="text-align-justify infinity-list">
                    <li>{t('pillars.e4.list1')}</li>
                    <li>{t('pillars.e4.list2')}</li>
                    <li>{t('pillars.e4.list3')}</li>
                    <li set:html={t('pillars.e4.list4')}/>
                </ul>
            </div>
        </div>
    </section>
    <section class="essentie back-red text-white">
		<h3 class="text-align-center" set:html={t("filosofie.essentie.text1")}/>
        <ul>
            <li set:html={t('filosofie.essentie.li1')}/>
            <li set:html={t('filosofie.essentie.li2')}/>
            <li set:html={t('filosofie.essentie.li3')}/>
        </ul>
        <p class="text-align-center">{t('filosofie.essentie.text2')}</p>
	</section>
    <section class="open-hart back-gray text-align-center">
        <h1 class="text-red">{t('filosofie.open-hart.title')}</h1>
        <p class="text-gray" set:html={t('filosofie.open-hart.text')}/>
    </section>
    <section class="s2 back-red text-white center">
        <div class="grid col3">
            <div>
                <p class="title">{t('filosofie.open-hart.s1.col1.title')}</p>
                <p>{t('filosofie.open-hart.s1.col1.text1')}</p>
                <ul>
                    <li>{t('filosofie.open-hart.s1.col1.list1')}</li>
                    <li>{t('filosofie.open-hart.s1.col1.list2')}</li>
                    <li>{t('filosofie.open-hart.s1.col1.list3')}</li>
                </ul>
                <p>{t('filosofie.open-hart.s1.col1.text2')}</p>
                <p>{t('filosofie.open-hart.s1.col1.text3')}</p>
            </div>
    
            <div>
                <p class="title">{t('filosofie.open-hart.s1.col2.title')}</p>
                <p>{t('filosofie.open-hart.s1.col2.text1')}</p>
                <p>{t('filosofie.open-hart.s1.col2.text2')}</p>
                <ul>
                    <li>{t('filosofie.open-hart.s1.col2.list1')}</li>
                    <li>{t('filosofie.open-hart.s1.col2.list2')}</li>
                    <li>{t('filosofie.open-hart.s1.col2.list3')}</li>
                </ul>
                <p>{t('filosofie.open-hart.s1.col2.text3')}</p>
            </div>
    
            <div>
                <p class="title">{t('filosofie.open-hart.s1.col3.title')}</p>
                <p>{t('filosofie.open-hart.s1.col3.text1')}</p>
                <p>{t('filosofie.open-hart.s1.col3.text2')}</p>
                <ul>
                    <li>{t('filosofie.open-hart.s1.col3.list1')}</li>
                    <li>{t('filosofie.open-hart.s1.col3.list2')}</li>
                    <li>{t('filosofie.open-hart.s1.col3.list3')}</li>
                </ul>
                <p>{t('filosofie.open-hart.s1.col3.text3')}</p>
            </div>
        </div>
    </section>

    <section class="s3 back-gray text-gray center">
        <div class="grid col3">
            <div>
                <p class="title">{t('filosofie.open-hart.s2.col1.title')}</p>
                <p>{t('filosofie.open-hart.s2.col1.text1')}</p>
                <ul>
                    <li>{t('filosofie.open-hart.s2.col1.list1')}</li>
                    <li>{t('filosofie.open-hart.s2.col1.list2')}</li>
                    <li>{t('filosofie.open-hart.s2.col1.list3')}</li>
                </ul>
                <p>{t('filosofie.open-hart.s2.col1.text2')}</p>
            </div>
            <div>
                <p class="title">{t('filosofie.open-hart.s2.col2.title')}</p>
                <p>{t('filosofie.open-hart.s2.col2.text1')}</p>
                <p>{t('filosofie.open-hart.s2.col2.text2')}</p>
                <ul>
                    <li>{t('filosofie.open-hart.s2.col2.list1')}</li>
                    <li>{t('filosofie.open-hart.s2.col2.list2')}</li>
                    <li>{t('filosofie.open-hart.s2.col2.list3')}</li>
                </ul>
                <p>{t('filosofie.open-hart.s2.col2.text3')}</p>
            </div>
            <div>
                <p class="title">{t('filosofie.open-hart.s2.col3.title')}</p>
                <p>{t('filosofie.open-hart.s2.col3.text1')}</p>
                <p>{t('filosofie.open-hart.s2.col3.text2')}</p>
                <p>{t('filosofie.open-hart.s2.col3.text3')}</p>
            </div>
        </div>
    </section>
    <ContactSection color='red'/>
</Layout>

<style>
    section{
        padding: 2rem;
    }

    .title{
        font-weight: 600;
        font-size: 1.3rem;
    }

    .col2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        width: 100%;
        max-width: 1200px;
        align-items: start;
    }
    
    .img-container {
        position: relative;
        width: 100%;
        height: auto;

        max-width: 400px;
        overflow: hidden;
        cursor: pointer;
        margin: auto;
    }

    .img-container img {
        display: block;
        width: 100%;
        height: auto;
    }

    .img-text {
        position: absolute;
        top: 0;
        left: 0;    
        text-align: center;
        width: 100%;
        height: 100%;
        
        padding: 40px; 
        box-sizing: border-box;
        border-radius: 50%;
        color: white;
        background-color: rgba(0, 0, 0, 0.6);

        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
    
        opacity: 0;
        transition: opacity 0.6s ease;
    }

    .img-container:hover .img-text {
        opacity: 1;
    }

    .essentie ul{
        margin: auto;
        width: fit-content;
        background-color: var(--mooyo-gray);
        color: var(--mooyo-red);
        padding: 2rem 4rem;
        border-radius: 0.5rem;
    }

    /* Responsive */
    @media (max-width: 925px) {
        .col2 {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        .pillars img {
            max-width: 100%;
        }
    }
</style>