---
import { Image } from 'astro:assets';
import Layout from "../../layouts/Layout.astro"
import hart_rond from '../../assets/rondevormen/hart_rond.png'
import zon from '../../assets/zon.jpg'
import uitzicht from '../../assets/zweden_uitzicht.jpg'
import { getLangFromUrl, useTranslations, getStaticPaths } from '../../i18n/utils';
export { getStaticPaths };
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title='Home'>
	<section class="s1 back-gray text-align-center text-gray center">
		<div class="container">
			<Image src={hart_rond} class="img" alt="Mooyo logo" width={550} height={550} loading="eager"/>
			<div class="text">
				<h1 class="text-red">Mooyo</h1>
				<p>{t("index.s1.text1")}</p>
				<p>{t("index.s1.text2")}</p>
				<p>∞ ∞ ∞</p>
				<p>{t("index.s1.text3")}</p>
				<p>∞ ∞ ∞</p>
				<p>{t("index.s1.text4")}</p>
				<p>∞ ∞ ∞</p>
				<p>{t("index.s1.text5")}</p>
			</div>
		</div>
	</section>
	<section class="s2 back-red text-white center">
		<div class="container">
			<Image src={zon} alt="tekening" class="img" width={500} height={500}/>
			<div>
				<h1 class="text-align-center">{t("index.s2.title")}</h1>
				<p set:html={t("index.s2.text")}></p>
				<p class="content-end">Francis Weller</p>
			</div>
		</div>
	</section>
	<section class="s3 back-gray text-align-center center">
		<div class="col3">
			<div>
				<p class="text-red text-align-center bold">{t("index.s3.col1.title")}</p>
				<p class="text-red text-align-center">{t("index.s3.col1.text1")}</p>
				<p class="text-gray text-align-justify" set:html={t("index.s3.col1.text2")}/>
			</div>
			<div>
				<p class="text-red text-align-center bold">{t("index.s3.col2.title")}</p>
				<p class="text-red text-align-center">{t("index.s3.col2.text1")}</p>
				<p class="text-gray text-align-justify" set:html={t("index.s3.col2.text2")}/>
			</div>
			<div>
				<p class="text-red text-align-center bold">{t("index.s3.col3.title")}</p>
				<p class="text-red text-align-center">{t("index.s3.col3.text1")}</p>
				<p class="text-gray text-align-justify" set:html={t("index.s3.col3.text2")}/>
				<p class="text-red text-align-justify" set:html={t("index.s3.col3.text3")}/>
			</div>
		</div>
	</section>
	<section class="s4 back-red text-align-center text-white">
		<p class="p2" set:html={t("index.s4.text")} />
	</section>
	<section class="s5 back-white">
		<Image src={uitzicht} class="img" alt="zweden foto"/>
		<div class="text">
			<h1 class="text-red">Bram Geysen</h1>
			<p class="text-gray">Rondestraat 38 <br> 3000 Leuven, Belgium</p>
			<p class="text-gray title">Contact</p>
			<p class="text-red">[+32 473 52 30 94]</p>
			<p class="text-red"><a href="mailto:bramgeysen@gmail.com" class="text-red">[bramgeysen@gmail.com]</a></p>
			<p class="text-gray title">Socials</p>
		</div>
	</section>
</Layout>

<style>
	section {
		padding: 2rem;
	}
	.s1 .container, .s2 .container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		max-width: 70rem;
		column-gap: 2rem;
	}
	
	.s2 .img {
		max-width: 500px;
		max-height: 500px;
		width: 100%;
		height: auto;
	}
	.s5 {
		display: grid;
		grid-template-columns: 1fr 1fr;
		padding: 0;
	}
	
	.s5 .img{
		width: 100%;
		height: auto;
		min-height: 500px;

	}

	.s5 .text{
		padding: 2rem;
	}

	.s5 .title{
		font-weight: 700;
	}

	.content-end {
		text-align: end;
	}


	/* Responsive */

	@media (max-width: 1200px){
		.s3 .col3{
			grid-template-columns: auto;
		}
	}

	@media (max-width: 900px){

		.s1 .container, .s2 .container, .s5 {
			grid-template-columns: auto;
		}
		.s1 .img{
			display: none;
		}

		.s2 .img, .s5 .img{
			grid-row: 2;
		}

		.s5{
			padding: 0;
		}
		.s5 .img{
			width: 100%;
		}
	}
</style>
